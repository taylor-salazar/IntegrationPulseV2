<mvc:View
	controllerName="integrationpulse.controller.IntegrationDetail"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.f"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core">

	<f:DynamicPage id="detailPage" showFooter="true" busy="{detailView>/busy}" busyIndicatorDelay="0">

		<!-- Title area -->
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{integration>/name}"/>
				</f:heading>
				<f:snappedHeading>
					<Title text="{integration>/name}"/>
				</f:snappedHeading>
				<f:expandedContent>
					<Text text="{integration>/description}"/>
				</f:expandedContent>
				<f:actions>
					<ObjectStatus
						text="{integration>/status}"
						state="{path: 'integration>/status', formatter: '.formatter.statusState'}"
						icon="{path: 'integration>/status', formatter: '.formatter.statusIcon'}"
						class="sapUiMediumMarginEnd"/>
				</f:actions>
				<f:navigationActions>
					<Button icon="sap-icon://nav-back" text="{i18n>backToIntegrations}" type="Transparent" press=".onNavBack"/>
				</f:navigationActions>
			</f:DynamicPageTitle>
		</f:title>

		<!-- Header facts -->
		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<f:content>
					<HBox wrap="Wrap" class="sapUiSmallMarginBottom">
						<VBox class="sapUiMediumMarginEnd">
							<Label text="{i18n>artifactId}"/>
							<Text text="{integration>/id}"/>
						</VBox>
						<VBox class="sapUiMediumMarginEnd">
							<Label text="{i18n>artifactPackage}"/>
							<Text text="{integration>/packageName}"/>
						</VBox>
						<VBox class="sapUiMediumMarginEnd">
							<Label text="{i18n>artifactVersion}"/>
							<Text text="v{integration>/version}"/>
						</VBox>
						<VBox>
							<Label text="{i18n>colLastDeployed}"/>
							<Text text="{path: 'integration>/lastDeployed', formatter: '.formatter.dateTime'}"/>
						</VBox>
					</HBox>
				</f:content>
			</f:DynamicPageHeader>
		</f:header>

		<!-- Parameters editor -->
		<f:content>
			<VBox class="sapUiContentPadding">
				<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
					<VBox>
						<Title text="{i18n>parametersTitle}" level="H3"/>
						<Text text="{i18n>parametersSubtitle}" class="ipMuted"/>
					</VBox>
					<MessageStrip
						visible="{detailView>/dirty}"
						text="{i18n>unsavedChanges}"
						type="Warning"
						showIcon="true"/>
				</HBox>

				<MessageStrip
					visible="{= ${parameters>/groups}.length === 0 }"
					text="{i18n>noParameters}"
					type="Information"
					showIcon="true"/>

				<!-- One panel per parameter group (extract.* / filter.* / delivery.* ...) -->
				<VBox items="{parameters>/groups}">
					<Panel headerText="{parameters>name}" expandable="true" expanded="true" class="sapUiSmallMarginBottom ipPanel">
						<List items="{parameters>params}" showSeparators="Inner" backgroundDesign="Transparent">
							<CustomListItem>
								<HBox alignItems="Center" justifyContent="SpaceBetween" wrap="Wrap" class="ipParamRow">
									<VBox class="ipParamLabel">
										<Label text="{parameters>label}" design="Bold"/>
										<Text text="{parameters>key}" class="ipMuted"/>
									</VBox>
									<Input
										width="22rem"
										value="{parameters>value}"
										type="{= ${parameters>secure} ? 'Password' : 'Text' }"
										placeholder="{parameters>defaultValue}"
										liveChange=".onParamChange"
										editable="{= !${parameters>readOnly} }"/>
								</HBox>
							</CustomListItem>
						</List>
					</Panel>
				</VBox>
			</VBox>
		</f:content>

		<!-- Sticky footer actions -->
		<f:footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Button text="{i18n>reset}" type="Transparent" enabled="{detailView>/dirty}" press=".onReset"/>
				<Button text="{i18n>save}" type="Default" enabled="{detailView>/dirty}" press=".onSaveDraft"/>
				<Button
					text="{i18n>deploy}"
					type="Emphasized"
					icon="sap-icon://upload-to-cloud"
					press=".onDeploy"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>
