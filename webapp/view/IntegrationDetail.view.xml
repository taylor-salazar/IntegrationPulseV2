<mvc:View
	controllerName="integrationpulse.controller.IntegrationDetail"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.f"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core">

	<f:DynamicPage id="detailPage" showFooter="true" busy="{detailView>/busy}" busyIndicatorDelay="0">

		<!-- Title area -->
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{integration>/name}"/>
				</f:heading>
				<f:snappedHeading>
					<Title text="{integration>/name}"/>
				</f:snappedHeading>
				<f:expandedContent>
					<Text text="{integration>/description}"/>
				</f:expandedContent>
				<f:actions>
					<ObjectStatus
						text="{integration>/status}"
						state="{path: 'integration>/status', formatter: '.formatter.statusState'}"
						icon="{path: 'integration>/status', formatter: '.formatter.statusIcon'}"
						class="sapUiMediumMarginEnd"/>
				</f:actions>
				<f:navigationActions>
					<Button icon="sap-icon://nav-back" text="{i18n>backToIntegrations}" type="Transparent" press=".onNavBack"/>
				</f:navigationActions>
			</f:DynamicPageTitle>
		</f:title>

		<!-- Header facts -->
		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<f:content>
					<HBox wrap="Wrap" class="sapUiSmallMarginBottom">
						<VBox class="sapUiMediumMarginEnd">
							<Label text="{i18n>artifactId}"/>
							<Text text="{integration>/id}"/>
						</VBox>
						<VBox class="sapUiMediumMarginEnd">
							<Label text="{i18n>artifactPackage}"/>
							<Text text="{integration>/packageName}"/>
						</VBox>
						<VBox class="sapUiMediumMarginEnd">
							<Label text="{i18n>artifactVersion}"/>
							<Text text="v{integration>/version}"/>
						</VBox>
						<VBox>
							<Label text="{i18n>colLastDeployed}"/>
							<Text text="{path: 'integration>/lastDeployed', formatter: '.formatter.dateTime'}"/>
						</VBox>
					</HBox>
				</f:content>
			</f:DynamicPageHeader>
		</f:header>

		<!-- Parameters editor -->
		<f:content>
			<VBox class="sapUiContentPadding">
				<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
					<VBox>
						<Title text="{i18n>parametersTitle}" level="H3"/>
						<Text text="{i18n>parametersSubtitle}" class="ipMuted"/>
					</VBox>
					<MessageStrip
						visible="{detailView>/dirty}"
						text="{i18n>unsavedChanges}"
						type="Warning"
						showIcon="true"/>
				</HBox>

				<MessageStrip
					visible="{= ${parameters>/groups}.length === 0 }"
					text="{i18n>noParameters}"
					type="Information"
					showIcon="true"/>

				<!-- One panel per parameter group (extract.* / filter.* / delivery.* ...) -->
				<VBox items="{parameters>/groups}">
					<Panel headerText="{parameters>name}" expandable="true" expanded="true" class="sapUiSmallMarginBottom ipPanel">
						<FlexBox
							items="{parameters>params}"
							wrap="Wrap"
							class="ipParamGrid">
							<items>
								<VBox class="ipParamCell">
									<VBox class="ipParamLabel">
										<Label text="{parameters>label}" design="Bold"/>
										<Text text="{parameters>key}" class="ipMuted"/>
									</VBox>
									<Input
										visible="{= !${parameters>isTimer} }"
										width="100%"
										value="{parameters>value}"
										type="{= ${parameters>secure} ? 'Password' : 'Text' }"
										placeholder="{parameters>defaultValue}"
										liveChange=".onParamChange"
										editable="{= !${parameters>readOnly} }"/>
									<VBox visible="{parameters>isTimer}" class="ipTimerEditor">
										<HBox wrap="Wrap" class="ipTimerLayout">
											<VBox class="ipTimerModeRail">
												<RadioButtonGroup
													columns="1"
													selectedIndex="{parameters>schedule/modeIndex}"
													select=".onTimerModeSelect"
													enabled="{= !${parameters>readOnly} }">
													<buttons>
														<RadioButton text="{i18n>timerRunOnce}"/>
														<RadioButton text="{i18n>timerScheduleOnDay}"/>
														<RadioButton text="{i18n>timerScheduleToRecur}"/>
														<RadioButton text="{i18n>timerAdvanced}"/>
													</buttons>
												</RadioButtonGroup>
											</VBox>

											<VBox class="ipTimerBody">
												<HBox visible="{= ${parameters>schedule/mode} === 'once' }" wrap="Wrap" class="ipTimerRow">
													<VBox class="ipTimerField">
														<Label text="{i18n>timerDate}"/>
														<DatePicker value="{parameters>schedule/onceDate}" valueFormat="yyyy-MM-dd" displayFormat="medium" change=".onTimerScheduleChange"/>
													</VBox>
													<VBox class="ipTimerField">
														<Label text="{i18n>timerTime}"/>
														<TimePicker value="{parameters>schedule/onceTime}" valueFormat="HH:mm" displayFormat="HH:mm" change=".onTimerScheduleChange"/>
													</VBox>
												</HBox>

												<HBox visible="{= ${parameters>schedule/mode} === 'day' }" wrap="Wrap" class="ipTimerRow">
													<VBox class="ipTimerField ipTimerWideField">
														<Label text="{i18n>timerDaysOfWeek}"/>
														<MultiComboBox
															width="100%"
															selectedKeys="{parameters>schedule/dayWeekdays}"
															selectionFinish=".onTimerScheduleChange"
															items="{scheduleOptions>/weekdays}">
															<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
														</MultiComboBox>
													</VBox>
													<VBox class="ipTimerField">
														<Label text="{i18n>timerTime}"/>
														<TimePicker value="{parameters>schedule/dayTime}" valueFormat="HH:mm" displayFormat="HH:mm" change=".onTimerScheduleChange"/>
													</VBox>
												</HBox>

												<HBox visible="{= ${parameters>schedule/mode} === 'recur' }" wrap="Wrap" class="ipTimerRow">
													<VBox class="ipTimerField">
														<Label text="{i18n>timerEvery}"/>
														<StepInput value="{parameters>schedule/recurEvery}" min="1" max="999" change=".onTimerScheduleChange"/>
													</VBox>
													<VBox class="ipTimerField">
														<Label text="{i18n>timerUnit}"/>
														<Select selectedKey="{parameters>schedule/recurUnit}" change=".onTimerScheduleChange" items="{scheduleOptions>/recurUnits}">
															<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
														</Select>
													</VBox>
													<VBox class="ipTimerField" visible="{= ${parameters>schedule/recurUnit} === 'days' }">
														<Label text="{i18n>timerStartingAt}"/>
														<TimePicker value="{parameters>schedule/recurStartTime}" valueFormat="HH:mm" displayFormat="HH:mm" change=".onTimerScheduleChange"/>
													</VBox>
												</HBox>

												<VBox visible="{= ${parameters>schedule/mode} === 'advanced' }" class="ipTimerAdvanced">
													<Text text="{i18n>timerAdvancedHelp}" class="ipMuted sapUiTinyMarginBottom"/>
													<HBox wrap="Wrap" class="ipTimerRow">
														<VBox class="ipTimerField">
															<Label text="{i18n>timerSeconds}"/>
															<Select selectedKey="{parameters>schedule/secondMode}" change=".onTimerScheduleChange" items="{scheduleOptions>/secondModes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</Select>
															<MultiComboBox selectedKeys="{parameters>schedule/seconds}" selectionFinish=".onTimerScheduleChange" items="{scheduleOptions>/seconds}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</MultiComboBox>
														</VBox>
														<VBox class="ipTimerField">
															<Label text="{i18n>timerMinutes}"/>
															<Select selectedKey="{parameters>schedule/minuteMode}" change=".onTimerScheduleChange" items="{scheduleOptions>/minuteModes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</Select>
															<MultiComboBox selectedKeys="{parameters>schedule/minutes}" selectionFinish=".onTimerScheduleChange" items="{scheduleOptions>/minutes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</MultiComboBox>
														</VBox>
														<VBox class="ipTimerField">
															<Label text="{i18n>timerHours}"/>
															<Select selectedKey="{parameters>schedule/hourMode}" change=".onTimerScheduleChange" items="{scheduleOptions>/hourModes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</Select>
															<MultiComboBox selectedKeys="{parameters>schedule/hours}" selectionFinish=".onTimerScheduleChange" items="{scheduleOptions>/hours}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</MultiComboBox>
														</VBox>
														<VBox class="ipTimerField">
															<Label text="{i18n>timerDays}"/>
															<Select selectedKey="{parameters>schedule/dayMode}" change=".onTimerScheduleChange" items="{scheduleOptions>/dayModes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</Select>
															<MultiComboBox selectedKeys="{parameters>schedule/days}" selectionFinish=".onTimerScheduleChange" items="{scheduleOptions>/days}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</MultiComboBox>
														</VBox>
														<VBox class="ipTimerField">
															<Label text="{i18n>timerMonths}"/>
															<Select selectedKey="{parameters>schedule/monthMode}" change=".onTimerScheduleChange" items="{scheduleOptions>/monthModes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</Select>
															<MultiComboBox selectedKeys="{parameters>schedule/months}" selectionFinish=".onTimerScheduleChange" items="{scheduleOptions>/months}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</MultiComboBox>
														</VBox>
														<VBox class="ipTimerField">
															<Label text="{i18n>timerYears}"/>
															<Select selectedKey="{parameters>schedule/yearMode}" change=".onTimerScheduleChange" items="{scheduleOptions>/yearModes}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</Select>
															<MultiComboBox selectedKeys="{parameters>schedule/years}" selectionFinish=".onTimerScheduleChange" items="{scheduleOptions>/years}">
																<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
															</MultiComboBox>
														</VBox>
													</HBox>
												</VBox>
											</VBox>
										</HBox>

										<HBox alignItems="Center" wrap="Wrap" class="ipTimerRow">
											<VBox class="ipTimerField ipTimerWideField">
												<Label text="{i18n>timerTimeZone}"/>
												<Select width="100%" selectedKey="{parameters>schedule/timeZone}" change=".onTimerScheduleChange" items="{scheduleOptions>/timeZones}">
													<core:Item key="{scheduleOptions>key}" text="{scheduleOptions>text}"/>
												</Select>
											</VBox>
											<VBox class="ipTimerField ipTimerCronPreview">
												<Label text="{i18n>timerCronPreview}"/>
												<Text text="{parameters>value}" class="ipMuted"/>
											</VBox>
										</HBox>
									</VBox>
								</VBox>
							</items>
						</FlexBox>
					</Panel>
				</VBox>

				<Panel
					headerText="{i18n>payloadsTitle}"
					expandable="true"
					expanded="false"
					class="sapUiSmallMarginTop ipPanel">
					<content>
						<MessageStrip
							visible="{= ${payloads>/items}.length === 0 }"
							text="{i18n>noPayloads}"
							type="Information"
							showIcon="true"
							class="sapUiSmallMarginBottom"/>
						<Table
							id="payloadsTable"
							growing="true"
							noDataText="{i18n>noPayloads}"
							items="{path: 'payloads>/items', sorter: { path: 'createdAt', descending: true }}">
							<columns>
								<Column><Text text="{i18n>colPayloadName}"/></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPayloadType}"/></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPayloadSize}"/></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPayloadCreated}"/></Column>
								<Column hAlign="End"><Text text="{i18n>colPayloadAction}"/></Column>
							</columns>
							<items>
								<ColumnListItem>
									<cells>
										<ObjectIdentifier title="{payloads>fileName}" text="{payloads>messageId}"/>
										<Text text="{payloads>contentType}"/>
										<ObjectNumber number="{path: 'payloads>sizeBytes', formatter: '.formatter.bytes'}"/>
										<Text text="{path: 'payloads>createdAt', formatter: '.formatter.dateTime'}"/>
										<Button
											icon="{= ${payloads>downloadOnly} ? 'sap-icon://download' : 'sap-icon://display' }"
											text="{= ${payloads>downloadOnly} ? ${i18n>downloadPayload} : ${i18n>viewPayload} }"
											type="Transparent"
											press=".onOpenPayload"/>
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</content>
				</Panel>
			</VBox>
		</f:content>

		<!-- Sticky footer actions -->
		<f:footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Button text="{i18n>reset}" type="Transparent" enabled="{detailView>/dirty}" press=".onReset"/>
				<Button text="{i18n>save}" type="Default" enabled="{detailView>/dirty}" press=".onSaveDraft"/>
				<Button
					text="{i18n>deploy}"
					type="Emphasized"
					icon="sap-icon://upload-to-cloud"
					press=".onDeploy"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>
