<mvc:View
	controllerName="integrationpulse.controller.MonitoringDetail"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.f">

	<f:DynamicPage id="monDetailPage" busy="{monDetailView>/busy}" busyIndicatorDelay="0">

		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{i18n>runHistoryTitle}"/>
				</f:heading>
				<f:expandedContent>
					<Text text="{monitoringItem>/name}"/>
				</f:expandedContent>
				<f:actions>
					<ObjectStatus
						text="{monitoringItem>/status}"
						state="{path: 'monitoringItem>/status', formatter: '.formatter.statusState'}"
						icon="{path: 'monitoringItem>/status', formatter: '.formatter.statusIcon'}"/>
				</f:actions>
				<f:navigationActions>
					<Button icon="sap-icon://nav-back" text="{i18n>backToMonitoring}" type="Transparent" press=".onNavBack"/>
					<Button icon="sap-icon://refresh" text="{i18n>refresh}" type="Transparent" press=".onRefresh"/>
				</f:navigationActions>
			</f:DynamicPageTitle>
		</f:title>

		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<f:content>
					<HBox wrap="Wrap" class="ipRunHistoryHeader">
						<VBox class="ipRunHistoryMetric">
							<Label text="{i18n>latestRunTitle}"/>
							<ObjectStatus
								text="{monDetailView>/summary/latestStatus}"
								state="{path: 'monDetailView>/summary/latestStatus', formatter: '.formatter.logState'}"/>
							<Text text="{path: 'monDetailView>/summary/latestTime', formatter: '.formatter.dateTime'}" class="ipMuted"/>
						</VBox>
						<VBox class="ipRunHistoryMetric">
							<Label text="{i18n>monitoringPassed}"/>
							<Text text="{monDetailView>/summary/passed}" class="ipMonitorMetricValue ipMonitorMetricGood"/>
						</VBox>
						<VBox class="ipRunHistoryMetric">
							<Label text="{i18n>monitoringFailed}"/>
							<Text text="{monDetailView>/summary/failed}" class="ipMonitorMetricValue ipMonitorMetricError"/>
						</VBox>
						<VBox class="ipRunHistoryMetric">
							<Label text="{i18n>monitoringWarned}"/>
							<Text text="{monDetailView>/summary/warnings}" class="ipMonitorMetricValue ipMonitorMetricWarning"/>
						</VBox>
						<VBox class="ipRunHistoryMetric">
							<Label text="{i18n>colEndpoint}"/>
							<Text text="{monitoringItem>/endpoint}"/>
						</VBox>
					</HBox>
				</f:content>
			</f:DynamicPageHeader>
		</f:header>

		<f:content>
			<VBox class="sapUiContentPadding">
				<Title text="{i18n>messageLogsTitle}" level="H3"/>
				<Text text="{i18n>runHistorySubtitle}" class="ipSubtitle sapUiSmallMarginBottom"/>

				<Table
					id="logsTable"
					growing="true"
					noDataText="{i18n>noLogs}"
					items="{path: 'logs>/items', sorter: { path: 'logEnd', descending: true }}">
					<columns>
						<Column hAlign="Center"><Text text="{i18n>colLogStatus}"/></Column>
						<Column><Text text="{i18n>colName}"/></Column>
						<Column><Text text="{i18n>colLogId}"/></Column>
						<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colResults}"/></Column>
						<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLogSender}"/></Column>
						<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLogTime}"/></Column>
						<Column hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLogDuration}"/></Column>
					</columns>
					<items>
						<ColumnListItem type="{= ${logs>status} === 'FAILED' ? 'Active' : 'Inactive' }" press=".onOpenLog">
							<cells>
								<ObjectStatus
									text="{logs>status}"
									state="{path: 'logs>status', formatter: '.formatter.logState'}"/>
								<ObjectIdentifier title="{logs>integrationName}" text="{logs>integrationId}"/>
								<ObjectIdentifier title="{logs>messageId}"/>
								<Link text="{logs>resultText}" visible="{logs>hasPayload}" press=".onOpenPayloadResult"/>
								<Text text="{logs>sender}"/>
								<Text text="{path: 'logs>logEnd', formatter: '.formatter.dateTime'}"/>
								<Text text="{path: 'logs>durationMs', formatter: '.formatter.duration'}"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</f:content>
	</f:DynamicPage>
</mvc:View>
