<mvc:View
	controllerName="integrationpulse.controller.Monitoring"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m">

	<Page id="monitoringPage" title="{i18n>monitoringTitle}" class="ipPage">

		<subHeader>
			<OverflowToolbar>
				<Text text="{i18n>monitoringSubtitle}" class="ipSubtitle"/>
				<ToolbarSpacer/>
				<SearchField width="16rem" placeholder="{i18n>searchIntegrations}" liveChange=".onSearch"/>
				<Button text="{i18n>sortBySourceSystem}" type="{= ${view>/groupMode} === 'source' ? 'Emphasized' : 'Default' }" press=".onGroupBySource"/>
				<Button text="{i18n>sortByTargetSystem}" type="{= ${view>/groupMode} === 'target' ? 'Emphasized' : 'Default' }" press=".onGroupByTarget"/>
				<ToggleButton text="{i18n>autoRefresh}" icon="sap-icon://synchronize" pressed="{view>/autoRefresh}" press=".onToggleAutoRefresh"/>
				<Button icon="sap-icon://refresh" tooltip="{i18n>refresh}" press=".onRefresh"/>
			</OverflowToolbar>
		</subHeader>

		<content>
			<MessageStrip
				visible="{view>/isMock}"
				text="{i18n>mockBannerText}"
				type="Information"
				showIcon="true"
				class="sapUiSmallMargin"/>

			<VBox class="ipMonitoringContent">
				<HBox wrap="Wrap" alignItems="Stretch" class="ipMonitorHealthBar">
					<VBox class="ipMonitorHealthMetric">
						<Text text="{i18n>monitoringRunning}" class="ipMonitorMetricLabel"/>
						<Text text="{view>/kpi/started}" class="ipMonitorMetricValue ipMonitorMetricGood"/>
					</VBox>
					<VBox class="ipMonitorHealthMetric">
						<Text text="{i18n>monitoringWarnings}" class="ipMonitorMetricLabel"/>
						<Text text="{view>/kpi/warnings}" class="ipMonitorMetricValue ipMonitorMetricWarning"/>
					</VBox>
					<VBox class="ipMonitorHealthMetric">
						<Text text="{i18n>monitoringErrors}" class="ipMonitorMetricLabel"/>
						<Text text="{view>/kpi/error}" class="ipMonitorMetricValue ipMonitorMetricError"/>
					</VBox>
					<VBox class="ipMonitorHealthMetric">
						<Text text="{i18n>monitoringMessages24h}" class="ipMonitorMetricLabel"/>
						<Text text="{view>/kpi/messages24h}" class="ipMonitorMetricValue"/>
					</VBox>
					<VBox class="ipMonitorHealthMeter">
						<HBox class="ipMonitorMeterLabels">
							<Text text="{i18n>monitoringHealthMix}" class="ipMonitorMetricLabel"/>
							<Text text="{view>/kpi/passPercent}%" class="ipMonitorMetricLabel"/>
						</HBox>
						<ProgressIndicator
							percentValue="{view>/kpi/passPercent}"
							displayValue="{view>/kpi/passPercent}%"
							state="Success"
							class="ipMonitorProgress"/>
					</VBox>
				</HBox>

				<VBox class="ipMonitorSection">
					<Title text="{parts: [{path: 'i18n>monitoringRecentVendors'}, {path: 'view>/groupLabel'}], formatter: '.formatter.formatMessage'}" level="H3" class="ipMonitorSectionTitle"/>
					<FlexBox
						wrap="Wrap"
						class="ipMonitorVendorGrid"
						items="{monitoring>/recentVendors}">
						<items>
							<CustomTile class="ipMonitorVendorTile" press=".onOpenSystemLogs">
								<VBox class="ipMonitorVendorTileInner">
									<VBox class="ipMonitorVendorTitleBlock">
										<Text text="{monitoring>name}" class="ipMonitorVendorName"/>
										<Text text="{monitoring>subtitle}" class="ipMonitorVendorSubtitle"/>
									</VBox>
									<HBox class="ipMonitorVendorCounts">
										<VBox>
											<Text text="{monitoring>passed}" class="ipMonitorCountValue ipMonitorMetricGood"/>
											<Text text="{i18n>monitoringPassed}" class="ipMonitorCountLabel"/>
										</VBox>
										<VBox>
											<Text text="{monitoring>failed}" class="ipMonitorCountValue ipMonitorMetricError"/>
											<Text text="{i18n>monitoringFailed}" class="ipMonitorCountLabel"/>
										</VBox>
										<VBox>
											<Text text="{monitoring>warnings}" class="ipMonitorCountValue ipMonitorMetricWarning"/>
											<Text text="{i18n>monitoringWarned}" class="ipMonitorCountLabel"/>
										</VBox>
									</HBox>
								</VBox>
							</CustomTile>
						</items>
					</FlexBox>
				</VBox>

				<VBox class="ipMonitorSection">
					<Title text="{parts: [{path: 'i18n>monitoringDeployedVendors'}, {path: 'view>/groupLabel'}], formatter: '.formatter.formatMessage'}" level="H3" class="ipMonitorSectionTitle"/>
					<FlexBox
						wrap="Wrap"
						class="ipMonitorVendorGrid"
						items="{monitoring>/deployedVendors}">
						<items>
							<CustomTile class="ipMonitorVendorTile" press=".onOpenSystemLogs">
								<VBox class="ipMonitorVendorTileInner">
									<VBox class="ipMonitorVendorTitleBlock">
										<Text text="{monitoring>name}" class="ipMonitorVendorName"/>
										<Text text="{monitoring>subtitle}" class="ipMonitorVendorSubtitle"/>
									</VBox>
									<HBox class="ipMonitorVendorCounts">
										<VBox>
											<Text text="{monitoring>passed}" class="ipMonitorCountValue ipMonitorMetricGood"/>
											<Text text="{i18n>monitoringPassed}" class="ipMonitorCountLabel"/>
										</VBox>
										<VBox>
											<Text text="{monitoring>failed}" class="ipMonitorCountValue ipMonitorMetricError"/>
											<Text text="{i18n>monitoringFailed}" class="ipMonitorCountLabel"/>
										</VBox>
										<VBox>
											<Text text="{monitoring>warnings}" class="ipMonitorCountValue ipMonitorMetricWarning"/>
											<Text text="{i18n>monitoringWarned}" class="ipMonitorCountLabel"/>
										</VBox>
									</HBox>
								</VBox>
							</CustomTile>
						</items>
					</FlexBox>
				</VBox>
			</VBox>
		</content>
	</Page>
</mvc:View>
