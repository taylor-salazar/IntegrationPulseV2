<mvc:View
	controllerName="integrationpulse.controller.Home"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m">

	<Page title="{i18n>homeTitle}" showHeader="true" class="ipPage">
		<content>
			<VBox class="sapUiContentPadding ipHomeContent">
				<FlexBox class="ipHomeTiles" wrap="Wrap">
					<items>
						<GenericTile
							class="ipHomeTile"
							header="{i18n>navIntegrations}"
							subheader="{i18n>homeIntegrationsSubtitle}"
							press=".onOpenIntegrations">
							<tileContent>
								<TileContent footer="{i18n>homeOpen}">
									<content>
										<NumericContent icon="sap-icon://chain-link" value=""/>
									</content>
								</TileContent>
							</tileContent>
						</GenericTile>

						<GenericTile
							class="ipHomeTile"
							header="{i18n>navMonitoring}"
							subheader="{i18n>homeMonitoringSubtitle}"
							press=".onOpenMonitoring">
							<tileContent>
								<TileContent footer="{i18n>homeOpen}">
									<content>
										<NumericContent icon="sap-icon://activity-2" value=""/>
									</content>
								</TileContent>
							</tileContent>
						</GenericTile>
					</items>
				</FlexBox>

				<VBox class="ipHomeLastRunsSection">
					<Title text="{i18n>homeLastRunsTitle}" level="H3"/>
					<Text text="{i18n>homeLastRunsSubtitle}" class="ipSubtitle sapUiSmallMarginBottom"/>

					<ScrollContainer
						height="22rem"
						vertical="true"
						horizontal="false"
						focusable="true"
						class="ipHomeLastRunsScroller">
						<Table
							id="homeLastRunsTable"
							busy="{home>/busy}"
							busyIndicatorDelay="0"
							noDataText="{i18n>homeNoLastRuns}"
							items="{path: 'home>/lastRuns'}"
							class="ipHomeLastRunsTable">
							<columns>
								<Column width="24rem"><Text text="{i18n>colVendor}"/></Column>
								<Column width="8rem"><Text text="{i18n>colStatus}"/></Column>
								<Column width="8rem" hAlign="Center"><Text text="{i18n>colUnderReview}"/></Column>
								<Column width="9rem" hAlign="Center"><Text text="{i18n>colUnresolvedIssues}"/></Column>
								<Column width="12rem" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLogTime}"/></Column>
								<Column width="7rem" hAlign="End"><Text text=""/></Column>
							</columns>
							<items>
								<ColumnListItem>
									<cells>
										<ObjectIdentifier title="{home>vendor}" text="{home>integrationName}"/>
										<ObjectStatus
											text="{home>status}"
											state="{path: 'home>status', formatter: '.formatter.logState'}"/>
										<CheckBox
											selected="{home>underReview}"
											select=".onUnderReviewSelect"/>
										<ObjectNumber
											number="{home>unresolvedIssues}"
											state="{= ${home>unresolvedIssues} > 0 ? 'Error' : 'Success' }"/>
										<Text text="{path: 'home>time', formatter: '.formatter.dateTime'}"/>
										<Link text="{i18n>seeDetails}" press=".onOpenMonitoringDetail"/>
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</ScrollContainer>
				</VBox>
			</VBox>
		</content>
	</Page>
</mvc:View>
