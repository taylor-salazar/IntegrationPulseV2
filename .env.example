# Integration Pulse — backend (FastAPI proxy) configuration
# Copy to backend/.env and fill in. NOTHING here is required for demo/mock mode.

# Demo switch. true  = serve local fixtures, no BTP access needed (default)
#              false = call the real SAP BTP Integration Suite API
INTEGRATION_PULSE_USE_MOCK=true

# --- SAP BTP Integration Suite (Cloud Integration) OData API ---
# Base URL up to and including /api/v1
INTEGRATION_PULSE_IS_API_BASE=https://<tenant>.it-cpi0xx.cfapps.<region>.hana.ondemand.com/api/v1

# --- OAuth2 client-credentials (from the IS API service key / XSUAA) ---
INTEGRATION_PULSE_OAUTH_TOKEN_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com/oauth/token
INTEGRATION_PULSE_CLIENT_ID=
INTEGRATION_PULSE_CLIENT_SECRET=

# --- CORS: which origins may call this proxy (comma-separated) ---
# Add your SAPUI5 dev-server origin and the SuccessFactors host.
INTEGRATION_PULSE_CORS_ORIGINS=http://localhost:8080,http://localhost:8081

# --- SuccessFactors embedding: who may iframe the app (CSP frame-ancestors) ---
# e.g. 'self' https://<your-company>.successfactors.eu https://<your-company>.sapsf.eu
INTEGRATION_PULSE_FRAME_ANCESTORS='self'

# --- Payload PostgreSQL storage ---
# In BTP Cloud Foundry, the backend can auto-detect a bound PostgreSQL service
# from VCAP_SERVICES. Set this only when running locally or when you prefer an
# explicit database URL.
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
INTEGRATION_PULSE_PAYLOAD_DATABASE_URL=
